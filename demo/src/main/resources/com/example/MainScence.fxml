<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.Controller"
      padding="20">

    <Label text="Cafe Order"
           style="-fx-font-size:20px; -fx-font-weight:bold;" />

    <HBox spacing="12">
        <VBox alignment="CENTER">
            <ImageView fitHeight="100" fitWidth="100" preserveRatio="true">
                <image>
                    <Image url="@mocca.PNG"/>
                </image>
            </ImageView>
            <Label text="Mocha"/>
        </VBox>

        <VBox alignment="CENTER">
            <ImageView fitHeight="100" fitWidth="100" preserveRatio="true">
                <image>
                    <Image url="@latte.PNG"/>
                </image>
            </ImageView>
            <Label text="Latte"/>
        </VBox>

        <VBox alignment="CENTER">
            <ImageView fitHeight="100" fitWidth="100" preserveRatio="true">
                <image>
                    <Image url="@americano.PNG"/>
                </image>
            </ImageView>
            <Label text="Americano"/>
        </VBox>
    </HBox>

    <GridPane hgap="10" vgap="10">
        <Label text="Menu" GridPane.rowIndex="0"/>
        <ComboBox fx:id="menuBox" GridPane.columnIndex="1"/>

        <Label text="Size" GridPane.rowIndex="1"/>
        <ComboBox fx:id="sizeBox" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Sweet" GridPane.rowIndex="2"/>
        <ComboBox fx:id="sweetBox" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <Button text="Add Order" onAction="#addOrder"/>

    <TextArea fx:id="orderArea" prefHeight="200"/>

</VBox>